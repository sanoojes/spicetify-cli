{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 150,
  "useTabs": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "arrowParens": "always",
  "ignorePatterns": ["jsHelper/spicetifyWrapper.js"],
  "sortImports": {
    "newlinesBetwenen": true,
    "groups": ["type-import", ["builtin", "external"], "internal", ["parent", "sibling", "index"], "unknown"]
  }
}
